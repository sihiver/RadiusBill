# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── PostgreSQL ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=radius
DB_USER=radius
DB_PASSWORD=radpass
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT Auth ──────────────────────────────────────────────
JWT_SECRET=ganti_dengan_secret_yang_panjang_dan_random
JWT_EXPIRES_IN=24h

# ─── FreeRADIUS ────────────────────────────────────────────
# (Menggunakan DB yang sama — hanya config saja)
RADIUS_SECRET=testing123
RADIUS_HOST=127.0.0.1
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813

# ─── Mikrotik API (opsional) ───────────────────────────────
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASS=

# ─── Cache TTL (detik) ────────────────────────────────────
CACHE_TTL_PACKAGES=300
CACHE_TTL_VOUCHERS=30
CACHE_TTL_MEMBERS=60
CACHE_TTL_STATS=60
CACHE_TTL_RADIUS_LOGS=30
